# ============================================================
# .gitignore - App Catalogo
# Sistema de Gestión para Preventistas
# ============================================================

# ============================================================
# ENTORNO VIRTUAL Y PYTHON
# ============================================================
venv/
env/
.env
.venv/
ENV/
env.bak/
venv.bak/

# ============================================================
# ARCHIVOS DE PYTHON COMPILADOS
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyo

# ============================================================
# BASE DE DATOS
# ============================================================
*.db
*.sqlite
*.sqlite3
catalogo.db
distribuidora.db
data/*.db

# ============================================================
# ARCHIVOS DE CONFIGURACIÓN (SENSIBLES)
# ============================================================
.env
turso-facturar.txt
*.conf
*.config

# ============================================================
# EJECUTABLES Y ARCHIVOS DE DISTRIBUCIÓN
# ============================================================
dist/
build/
*.exe
*.msi
*.dmg
*.app
*.spec
*.egg-info/
*.egg

# ============================================================
# LOGS Y TEMPORALES
# ============================================================
*.log
logs/
*.tmp
*.temp
*.bak
*.backup
*.swp
*.swo
*~

# ============================================================
# EDITORES E IDEAS
# ============================================================
.vscode/
.idea/
*.iml
.DS_Store
Thumbs.db
*.suo
*.user
*.userosscache
*.sln.docstates

# ============================================================
# ARCHIVOS DE TESTS
# ============================================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.dmypy.json
dmypy.json

# ============================================================
# ARCHIVOS ESPECÍFICOS DEL PROYECTO
# ============================================================
*.bak
*.backup
corregir_ventana.py
estructura.txt
test

# ============================================================
# CARPETA DE IMÁGENES (SÍ SE SUBA)
# ============================================================
# ¡IMPORTANTE! 
# La carpeta imagenes_productos/ SÍ se sube al repositorio.
# Contiene fotos de ejemplo para el catálogo.
# ============================================================

# ============================================================
# ARCHIVOS DE BACKUP DEL SISTEMA
# ============================================================
*.bak
*.backup
*~

# ============================================================
# ARCHIVOS DE PRUEBAS LOCALES
# ============================================================
test
test.py
prueba.py
debug.py

# ============================================================
# ARCHIVOS DE COMPILACIÓN DE QT
# ============================================================
*.ui
*.qrc
*.qm
*.ts

# ============================================================
# ARCHIVOS DE INSTALACIÓN (SOLO PARA WINDOWS)
